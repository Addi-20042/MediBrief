# ========== SUPABASE CLIENT CONFIGURATION ==========
# Frontend environment variables (VITE prefix allows them to be accessed in browser)
# Get these from your Supabase project settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# ========== EDGE FUNCTION SECRETS ==========
# Set these using: supabase secrets set SECRET_NAME value
# These are only accessible to edge functions, not the frontend

# AI/LLM Services
# REQUIRED: Google Gemini API for chat and analysis features
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key

# Email Services (optional - pick one or both for email features)
# Brevo (formerly Sendinblue) for email sending
BREVO_API_KEY=your-brevo-api-key

# Resend as alternative email provider
RESEND_API_KEY=your-resend-api-key

# SMS Service (optional - for medication reminders via SMS)
FAST2SMS_API_KEY=your-fast2sms-api-key

# ========== GOOGLE OAUTH SETUP ==========
# Configure in Supabase Dashboard → Authentication → Providers → Google
# No environment variables needed here, but you need:
# 1. Google OAuth Client ID
# 2. Google OAuth Client Secret
# Get these from: https://console.cloud.google.com/
# Authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
